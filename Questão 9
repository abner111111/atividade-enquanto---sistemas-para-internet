programa {
  funcao inicio() {
    inteiro numero, contador = 0, repeticao = 0, meio

    enquanto(repeticao < 10){
      escreva("\nDigite um número: ")
      leia(numero)

      meio = numero / 2

      se(meio * 2 == numero){
        contador = contador + 1
      }

      repeticao = repeticao + 1
    }
    escreva("\nQuantidade de números pares digitados: ", contador)
  }
}
